{
  "name": "@liquad/sdk",
  "version": "0.4.0",
  "description": "Liquad AI Content Licensing SDK - Universal handler for Node.js and Edge runtimes",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js"
    },
    "./matcher": {
      "types": "./dist/matcher.d.ts",
      "import": "./dist/matcher.mjs",
      "require": "./dist/matcher.js"
    },
    "./url-normalize": {
      "types": "./dist/url-normalize.d.ts",
      "import": "./dist/url-normalize.mjs",
      "require": "./dist/url-normalize.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/express.ts src/matcher.ts src/url-normalize.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/express.ts src/matcher.ts src/url-normalize.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "liquad",
    "ai",
    "licensing",
    "sdk",
    "middleware",
    "edge",
    "cloudflare-workers",
    "vercel-edge"
  ],
  "license": "MIT"
}
