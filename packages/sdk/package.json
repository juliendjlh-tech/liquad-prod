{
  "name": "@liquad/sdk",
  "version": "0.1.0",
  "description": "Liquad AI Content Licensing SDK - Server-side middleware",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["liquad", "ai", "licensing", "sdk", "middleware"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
