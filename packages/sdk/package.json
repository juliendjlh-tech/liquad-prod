{
  "name": "@liquad/sdk",
  "version": "0.2.0",
  "description": "Liquad AI Content Licensing SDK - Universal handler for Node.js and Edge runtimes",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/express.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/express.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "liquad",
    "ai",
    "licensing",
    "sdk",
    "middleware",
    "edge",
    "cloudflare-workers",
    "vercel-edge"
  ],
  "license": "MIT",
  "dependencies": {
    "jose": "^6.2.0"
  }
}
